<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!--
      "RESOURCE_LOCAL" means this app manages its own transactions
      (EntityTransaction, in TodoRepository) rather than relying on a
      container/Spring to do it - the JPA equivalent of the manual
      transaction handling you'd write with plain JDBC.
    -->
    <persistence-unit name="todoPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.todoapp.Todo</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <!--
              Local-dev defaults. H2 runs embedded in this same process and
              stores its data in a file under persistence-service/data/, so
              there's no separate database server to start or configure -
              unlike Postgres, there's nothing here to install or run first.
              Database.java can still override these at runtime from
              DB_URL / DB_USER / DB_PASSWORD environment variables, e.g. to
              point this same code at a real Postgres instance later.
            -->
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:file:./data/tododb;AUTO_SERVER=TRUE"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>

            <!--
              Creates/updates the schema to match the @Entity classes on
              startup - the JPA equivalent of the CREATE TABLE IF NOT EXISTS
              this project used to run by hand under raw JDBC. Fine for a
              learning sample; a real service would use a migration tool
              (Flyway/Liquibase) instead of letting the ORM own the schema.
            -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
